# Copy to repo root as .env.gcp and source automatically by gcp-deploy.sh
GCP_PROJECT=your-gcp-project
GCP_REGION=us-central1
GCP_CLUSTER=astra-cluster
# Optional: override default bucket name (default: ${GCP_PROJECT}-astra-workspace)
# GCS_WORKSPACE_BUCKET=my-project-astra-workspace
POSTGRES_PASSWORD=change-me
# ASTRA_SUPER_ADMIN_EMAIL=admin@example.com
# ASTRA_SUPER_ADMIN_PASSWORD=change-me-admin
