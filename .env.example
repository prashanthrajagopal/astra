POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=astra
POSTGRES_USER=astra
POSTGRES_PASSWORD=changeme

REDIS_ADDR=localhost:6379

MEMCACHED_ADDR=localhost:11211

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

GRPC_PORT=9090
HTTP_PORT=8080

LOG_LEVEL=info
LOG_FORMAT=json

OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# Approval system: when true, goal-service skips plan approval and applies plans immediately.
AUTO_APPROVE_PLANS=false

# goal-service base URL (used by access-control to call /internal/apply-plan after approving a plan).
GOAL_SERVICE_ADDR=http://localhost:8088

# Workspace for code generation (used by execution workers)
WORKSPACE_ROOT=./workspace
TOOL_RUNTIME=workspace
LLM_GRPC_ADDR=localhost:9093

# LLM provider configuration
# If no cloud keys are set, Astra falls back to local Ollama.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# MLX-LM (Apple Silicon local inference)
MLX_HOST=http://localhost:8888
MLX_MODEL=Qwen2.5-7B-Instruct-4bit
LLM_DEFAULT_PROVIDER=ollama

# Optional cloud providers (set one or more)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Gemini model when LLM_DEFAULT_PROVIDER=gemini (default: gemini-1.5-pro). Examples: gemini-1.5-flash, gemini-2.0-flash.
GEMINI_MODEL=

# Chat (chat agents feature)
# Enable chat WebSocket and sessions API
CHAT_ENABLED=false
CHAT_MAX_MSG_LENGTH=65536
CHAT_RATE_LIMIT=30
CHAT_TOKEN_CAP=100000

# Multi-Tenancy: Super-admin seed credentials
# Used by deploy.sh to seed the initial super-admin user on first run.
ASTRA_SUPER_ADMIN_EMAIL=admin@admin.com
ASTRA_SUPER_ADMIN_PASSWORD=password

# Slack integration (optional)
# Signing secret from api.slack.com/apps → your app → Basic Information. Or set via Super-Admin → Slack UI.
SLACK_SIGNING_SECRET=
# Shared secret for slack-adapter to call api-gateway internal Slack/chat endpoints.
# In production, set to a strong random value; empty disables the check (internal endpoints still reachable).
ASTRA_SLACK_INTERNAL_SECRET=
# URL of api-gateway (slack-adapter calls this for chat).
GATEWAY_INTERNAL_URL=http://localhost:8080
SLACK_ADAPTER_PORT=8095

# External event ingest (optional)
# Secret for POST /internal/ingest/event. Adapters (GCP Pub/Sub, external Redis, WebSocket) send this header to push events to agents.
# In production, set to a strong random value; empty disables the check (internal endpoint still reachable).
ASTRA_INGEST_SECRET=
# Rate limit for POST /internal/ingest/event: max requests per agent per minute (default 100).
# ASTRA_INGEST_RATE_LIMIT=100

# --- Ingest adapters: set these in the *adapter's* .env. Which agent listens is configured per-agent (PATCH /agents/{id}: ingest_source_type, ingest_source_config). Adapters call GET /internal/ingest/bindings to discover. ---

# Adapter: Redis Pub/Sub (external Redis, separate from Astra's REDIS_ADDR)
# ASTRA_INGEST_URL=http://localhost:8080
# ASTRA_INGEST_SECRET=<same-as-gateway>
# EXTERNAL_REDIS_ADDR=external-redis.example.com:6379
# EXTERNAL_REDIS_PASSWORD=

# Adapter: GCP Pub/Sub
# ASTRA_INGEST_URL=http://localhost:8080
# ASTRA_INGEST_SECRET=<same-as-gateway>
# GCP_PROJECT=my-gcp-project
# GCP_SUBSCRIPTION=my-subscription
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Adapter: External WebSocket
# ASTRA_INGEST_URL=http://localhost:8080
# ASTRA_INGEST_SECRET=<same-as-gateway>
# EXTERNAL_WS_URL=wss://example.com/events
# EXTERNAL_WS_API_KEY=
